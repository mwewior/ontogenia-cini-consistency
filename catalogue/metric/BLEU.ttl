<https://w3id.org/bench4ke/metric/BLEU> a dqv:Metric, ftr:Test ;
    dcterms:identifier "https://w3id.org/bench4ke/metric/BLEU" ;
    dcterms:title      "BLEU Score"@en ;
    rdfs:label         "BLEU: n-gram precision with brevity penalty for CQ evaluation"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/metric/BLEU> ;
    dcterms:description """BLEU (Bilingual Evaluation Understudy) measures modified n-gram precision between a generated CQ
(hypothesis) and a gold-standard CQ (reference), with a brevity penalty for short hypotheses.
Bench4KE computes sentence-level BLEU using NLTK's sentence_bleu function with add-1 (method1)
smoothing applied to avoid zero scores on unseen n-grams.

The score is averaged over all generated×gold CQ pairs.

Range: [0, 1]. Higher values indicate greater n-gram overlap with gold-standard CQs.
BLEU was originally designed for machine translation; when applied to CQ evaluation it captures
shared vocabulary and short phrases but is sensitive to exact wording and may penalise valid
paraphrases."""@en ;
    dcat:keyword       "Metric"@en,
    "BLEU"@en,
    "N-gram"@en,
    "Lexical Similarity"@en,
    "Bench4KE"@en ;
    dqv:inDimension    <https://w3id.org/bench4ke/dimension/LexicalSimilarity> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://w3id.org/bench4ke/org/unibo> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

<https://orcid.org/0000-0002-0266-3452> a vcard:Individual ;
    vcard:fn       "Anna Sofia Lippolis" ;
    vcard:hasEmail <mailto:annasofia.lippolis2@unibo.it> ;
    vcard:url      <https://orcid.org/0000-0002-0266-3452> .

<https://w3id.org/bench4ke/org/unibo> a vcard:Organization, foaf:Organization ;
    vcard:fn  "University of Bologna" ;
    vcard:url <https://www.unibo.it/> .

<https://w3id.org/bench4ke> a ftr:Benchmark ;
    dcterms:title      "Bench4KE"@en ;
    dcterms:identifier "https://w3id.org/bench4ke" ;
