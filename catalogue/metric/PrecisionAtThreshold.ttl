<https://w3id.org/bench4ke/metric/PrecisionAtThreshold> a dqv:Metric, ftr:Test ;
    dcterms:identifier "https://w3id.org/bench4ke/metric/PrecisionAtThreshold" ;
    dcterms:title      "Precision at Threshold"@en ;
    rdfs:label         "PrecisionAtThreshold: fraction of generated CQs matched to at least one gold CQ above threshold"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/metric/PrecisionAtThreshold> ;
    dcterms:description """Precision at Threshold measures the fraction of generated CQs whose best cosine similarity to any
gold-standard CQ meets or exceeds the threshold (default 0.6), using SBERT sentence embeddings.

Formula:
  P@t = |{g in G : max_{m in M} cos(embed(g), embed(m)) >= t}| / |G|

where G is the set of generated CQs, M is the set of gold-standard CQs, and t = 0.6.

Range: [0, 1]. Precision at Threshold is the discrete counterpart of MeanBestMatchCosine:
while MeanBestMatchCosine reports the average similarity of best matches, P@t counts how many
generated CQs clear the relevance bar. A high score indicates that most generated CQs are
semantically grounded in the gold standard."""@en ;
    dcat:keyword       "Metric"@en,
    "Precision"@en,
    "Threshold"@en,
    "Coverage"@en,
    "Bench4KE"@en ;
    dqv:inDimension    <https://w3id.org/bench4ke/dimension/Coverage> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    rdfs:seeAlso    <https://w3id.org/cq4oe/metric/Precision> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452>,
                       <https://orcid.org/0009-0009-4332-1780> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://ror.org/01111rn36>,
                       <https://ror.org/05w9g2j85>,
                       <https://stlab.istc.cnr.it/stlab/> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

