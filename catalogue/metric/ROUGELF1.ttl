<https://w3id.org/bench4ke/metric/ROUGELF1> a dqv:Metric, ftr:Test ;
    dcterms:identifier "https://w3id.org/bench4ke/metric/ROUGELF1" ;
    dcterms:title      "ROUGE-L F1"@en ;
    rdfs:label         "ROUGELF1: longest common subsequence F1 between generated and gold-standard CQs"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/metric/ROUGELF1> ;
    dcterms:description """ROUGE-L (Recall-Oriented Understudy for Gisting Evaluation — Longest Common Subsequence) measures
the longest common token subsequence (LCS) between a generated CQ and a gold-standard CQ.
Bench4KE reports the F1 variant (harmonic mean of LCS-precision and LCS-recall), computed with the
rouge_score library using the rougeLsum scorer and stemming enabled.

The score is averaged over all generated×gold CQ pairs.

Range: [0, 1]. ROUGE-L captures structural similarity while being insensitive to gaps: tokens need
not be contiguous in either sequence to contribute to the LCS. Like BLEU, it is a lexical metric
and does not account for semantic paraphrasing."""@en ;
    dcat:keyword       "Metric"@en,
    "ROUGE-L"@en,
    "LCS"@en,
    "Lexical Similarity"@en,
    "Bench4KE"@en ;
    dqv:inDimension    <https://w3id.org/bench4ke/dimension/LexicalSimilarity> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://w3id.org/bench4ke/org/unibo> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

<https://orcid.org/0000-0002-0266-3452> a vcard:Individual ;
    vcard:fn       "Anna Sofia Lippolis" ;
    vcard:hasEmail <mailto:annasofia.lippolis2@unibo.it> ;
    vcard:url      <https://orcid.org/0000-0002-0266-3452> .

