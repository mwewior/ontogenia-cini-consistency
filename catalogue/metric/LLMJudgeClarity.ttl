<https://w3id.org/bench4ke/metric/LLMJudgeClarity> a dqv:Metric, ftr:Test ;
    dcterms:identifier "https://w3id.org/bench4ke/metric/LLMJudgeClarity" ;
    dcterms:title      "LLM Judge — Clarity"@en ;
    rdfs:label         "LLMJudgeClarity: 1-5 LLM-rated linguistic clarity of each generated CQ"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/metric/LLMJudgeClarity> ;
    dcterms:description """LLM Judge Clarity is an intrinsic quality score assigned by a large language model evaluator to
each generated competency question, rating its linguistic well-formedness, unambiguity, and ease
of interpretation. The LLM evaluator scores each CQ on a 1–5 integer scale:

  1 — ambiguous, grammatically incorrect, or very hard to interpret
  5 — clear, grammatically correct, and unambiguous

Scores are produced without reference to a gold standard (intrinsic evaluation). The evaluator LLM
must differ from the tool's generation LLM to avoid self-evaluation bias.

Range: [1, 5]. Clarity is essential for CQs used as formal requirements: an ontology engineer
must be able to translate each CQ into a SPARQL query or logical axiom without further
clarification."""@en ;
    dcat:keyword       "Metric"@en,
    "LLM-as-Judge"@en,
    "Clarity"@en,
    "Intrinsic Evaluation"@en,
    "Bench4KE"@en ;
    dqv:inDimension    <https://w3id.org/bench4ke/dimension/LLMEvaluation> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://w3id.org/bench4ke/org/unibo> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

<https://orcid.org/0000-0002-0266-3452> a vcard:Individual ;
