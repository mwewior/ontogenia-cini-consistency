<https://w3id.org/bench4ke/metric/JaccardSimilarity> a dqv:Metric, ftr:Test ;
    dcterms:identifier "https://w3id.org/bench4ke/metric/JaccardSimilarity" ;
    dcterms:title      "Jaccard Similarity"@en ;
    rdfs:label         "JaccardSimilarity: token-set overlap between generated and gold-standard CQs"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/metric/JaccardSimilarity> ;
    dcterms:description """Jaccard Similarity measures the overlap between the token sets of a generated CQ and a gold-standard CQ.
For each generated-gold pair, it is defined as:

  J(A, B) = |A ∩ B| / |A ∪ B|

where A and B are the sets of whitespace-tokenised words in the generated and gold CQ respectively.
The metric is averaged over all generated×gold CQ pairs.

Range: [0, 1]. A score of 1 indicates identical token sets; 0 indicates no shared tokens.
Jaccard is a purely lexical metric: it does not account for word order, morphological variation, or
semantic paraphrasing. It complements embedding-based metrics by providing an interpretable baseline."""@en ;
    dcat:keyword       "Metric"@en,
    "Jaccard"@en,
    "Lexical Similarity"@en,
    "Bench4KE"@en ;
    dqv:inDimension    <https://w3id.org/bench4ke/dimension/LexicalSimilarity> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452>,
                       <https://orcid.org/0009-0009-4332-1780> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://ror.org/01111rn36>,
                       <https://ror.org/05w9g2j85>,
                       <https://stlab.istc.cnr.it/stlab/> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

