<https://w3id.org/bench4ke/metric/BERTScorePrecision> a dqv:Metric, ftr:Test ;
    dcterms:identifier "https://w3id.org/bench4ke/metric/BERTScorePrecision" ;
    dcterms:title      "BERTScore Precision"@en ;
    rdfs:label         "BERTScorePrecision: contextual token-level precision of generated CQs against gold standard"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/metric/BERTScorePrecision> ;
    dcterms:description """BERTScore Precision measures the average contextual similarity of generated CQ tokens to their
best-matching gold-standard CQ tokens. For each generated token, the maximum cosine similarity to
any gold token (using microsoft/deberta-xlarge-mnli embeddings) is computed; the mean across all
generated tokens gives the precision for that pair. Averaged over all generated×gold pairs.

Range: [0, 1]. High BERTScore Precision indicates that generated CQ tokens are semantically
grounded in the gold standard. It may be high even when recall is low (i.e., generated CQs are
relevant but incomplete)."""@en ;
    dcat:keyword       "Metric"@en,
    "BERTScore"@en,
    "Precision"@en,
    "Contextual Embeddings"@en,
    "Semantic Similarity"@en,
    "Bench4KE"@en ;
    dqv:inDimension    <https://w3id.org/bench4ke/dimension/SemanticSimilarity> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452>,
                       <https://orcid.org/0009-0009-4332-1780> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://ror.org/01111rn36>,
                       <https://ror.org/05w9g2j85>,
                       <https://stlab.istc.cnr.it/stlab/> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

