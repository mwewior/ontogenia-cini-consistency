<https://w3id.org/bench4ke/metric/HitRate> a dqv:Metric, ftr:Test ;
    dcterms:identifier "https://w3id.org/bench4ke/metric/HitRate" ;
    dcterms:title      "Hit Rate"@en ;
    rdfs:label         "HitRate: fraction of benchmark CQs matched by at least one generated CQ above threshold"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/metric/HitRate> ;
    dcterms:description """Hit Rate (Phase 1 coverage) measures the fraction of benchmark gold-standard CQs for which at
least one generated CQ achieves a cosine similarity at or above a defined threshold (default 0.6),
using SBERT (all-MiniLM-L6-v2) sentence embeddings.

Formula:
  HitRate = |{m in M : max_{g in G} cos(embed(g), embed(m)) >= t}| / |M|

where M is the set of benchmark CQs, G is the set of generated CQs, and t is the threshold (0.6).

Range: [0, 1]. A score of 1 indicates that every benchmark CQ was semantically matched by at least
one generated CQ. This is the primary Phase 1 metric of Bench4KE's two-phase hit-rate evaluation.

See also: AugmentedHitRate (Phase 2, with LLM gap filling)."""@en ;
    dcat:keyword       "Metric"@en,
    "Hit Rate"@en,
    "Coverage"@en,
    "Threshold"@en,
    "Bench4KE"@en ;
    dqv:inDimension    <https://w3id.org/bench4ke/dimension/Coverage> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    rdfs:seeAlso    <https://w3id.org/cq4oe/metric/AtLeastOneCoverage> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452>,
                       <https://orcid.org/0009-0009-4332-1780> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://ror.org/01111rn36>,
                       <https://ror.org/05w9g2j85>,
                       <https://stlab.istc.cnr.it/stlab/> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

