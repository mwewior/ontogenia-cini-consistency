<https://w3id.org/bench4ke/metric/BERTScoreRecall> a dqv:Metric, ftr:Test ;
    dcterms:identifier "https://w3id.org/bench4ke/metric/BERTScoreRecall" ;
    dcterms:title      "BERTScore Recall"@en ;
    rdfs:label         "BERTScoreRecall: contextual token-level recall of gold CQs covered by generated CQs"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/metric/BERTScoreRecall> ;
    dcterms:description """BERTScore Recall measures the average contextual similarity of gold-standard CQ tokens to their
best-matching generated CQ tokens. For each gold token, the maximum cosine similarity to any
generated token (using microsoft/deberta-xlarge-mnli embeddings) is computed; the mean across all
gold tokens gives the recall for that pair. Averaged over all generated×gold pairs.

Range: [0, 1]. High BERTScore Recall indicates that the content of gold-standard CQs is well
represented in the generated output. It may be high even when precision is low (i.e., generated
CQs cover the gold standard but include much irrelevant content)."""@en ;
    dcat:keyword       "Metric"@en,
    "BERTScore"@en,
    "Recall"@en,
    "Contextual Embeddings"@en,
    "Semantic Similarity"@en,
    "Bench4KE"@en ;
    dqv:inDimension    <https://w3id.org/bench4ke/dimension/SemanticSimilarity> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://w3id.org/bench4ke/org/unibo> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

<https://orcid.org/0000-0002-0266-3452> a vcard:Individual ;
    vcard:fn       "Anna Sofia Lippolis" ;
    vcard:hasEmail <mailto:annasofia.lippolis2@unibo.it> ;
    vcard:url      <https://orcid.org/0000-0002-0266-3452> .

