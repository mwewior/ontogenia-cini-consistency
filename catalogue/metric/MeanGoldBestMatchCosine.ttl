<https://w3id.org/bench4ke/metric/MeanGoldBestMatchCosine> a dqv:Metric, ftr:Test ;
    dcterms:identifier "https://w3id.org/bench4ke/metric/MeanGoldBestMatchCosine" ;
    dcterms:title      "Mean Gold Best-Match Cosine (recall-oriented)"@en ;
    rdfs:label         "MeanGoldBestMatchCosine: mean of per-gold-CQ maximum cosine similarity to any generated CQ"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/metric/MeanGoldBestMatchCosine> ;
    dcterms:description """Mean Gold Best-Match Cosine (recall-oriented) evaluates coverage of the gold standard by finding,
for each gold-standard CQ, its closest generated CQ in SBERT embedding space. The maximum cosine
similarity for each gold CQ is then averaged across all gold CQs.

Formula:
  score = mean_{m in M} max_{g in G} cos(embed(g), embed(m))

Range: [0, 1]. This metric is recall-oriented: it measures whether each gold-standard CQ has at
least one semantically close generated CQ. A high score indicates broad coverage of the benchmark.

See also: MeanBestMatchCosine (precision-oriented complement)."""@en ;
    dcat:keyword       "Metric"@en,
    "Cosine Similarity"@en,
    "SBERT"@en,
    "Best Match"@en,
    "Semantic Similarity"@en,
    "Bench4KE"@en ;
    dqv:inDimension    <https://w3id.org/bench4ke/dimension/SemanticSimilarity> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    rdfs:seeAlso    <https://w3id.org/cq4oe/metric/SemanticCosineSimilarity> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452>,
                       <https://orcid.org/0009-0009-4332-1780> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://ror.org/01111rn36>,
                       <https://ror.org/05w9g2j85>,
                       <https://stlab.istc.cnr.it/stlab/> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

