<https://w3id.org/bench4ke/dimension/Coverage> a dqv:Dimension ;
    dcterms:identifier "https://w3id.org/bench4ke/dimension/Coverage" ;
    dcterms:title      "Coverage"@en ;
    rdfs:label         "Coverage: extent to which generated CQs cover the gold-standard benchmark"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/dimension/Coverage> ;
    dcterms:description """Coverage measures how well the set of generated competency questions addresses the questions in the
benchmark gold standard. A benchmark CQ is considered hit if at least one generated CQ achieves a
cosine similarity above a defined threshold (default 0.6) using SBERT embeddings.

The dimension includes two phases: Phase 1 computes baseline coverage from the tool output alone;
Phase 2 applies LLM-assisted gap filling, where an independent evaluator LLM proposes candidate CQs
for missed benchmark items, and counts how many additional benchmark CQs can thereby be recovered."""@en ;
    dcat:keyword       "Coverage"@en,
    "Hit Rate"@en,
    "Benchmark Evaluation"@en,
    "Bench4KE"@en ;
    dqv:hasQualityMetric
        <https://w3id.org/bench4ke/metric/HitRate>,
        <https://w3id.org/bench4ke/metric/AugmentedHitRate>,
        <https://w3id.org/bench4ke/metric/PrecisionAtThreshold> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452>,
                       <https://orcid.org/0009-0009-4332-1780> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://ror.org/01111rn36>,
                       <https://ror.org/05w9g2j85>,
                       <https://stlab.istc.cnr.it/stlab/> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

<https://orcid.org/0000-0002-0266-3452> a vcard:Individual ;
    vcard:fn       "Anna Sofia Lippolis" ;
