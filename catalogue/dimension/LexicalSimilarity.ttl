<https://w3id.org/bench4ke/dimension/LexicalSimilarity> a dqv:Dimension ;
    dcterms:identifier "https://w3id.org/bench4ke/dimension/LexicalSimilarity" ;
    dcterms:title      "Lexical Similarity"@en ;
    rdfs:label         "LexicalSimilarity: token-level textual overlap between generated and gold-standard CQs"^^xsd:string ;
    dcat:version       "0.1.0"^^xsd:string ;
    ftr:status         "Active"@en ;
    dcat:landingPage   <https://w3id.org/bench4ke/dimension/LexicalSimilarity> ;
    dcterms:description """Lexical Similarity captures surface-level textual overlap between generated competency questions and
gold-standard CQs using token-based comparison methods. Metrics in this dimension compare word sets or
n-gram sequences directly, without any semantic encoding.

Lexical metrics are fast to compute and interpretable, but are insensitive to paraphrasing: two CQs with
identical meaning but different wording will score low. They are best used alongside semantic metrics to
provide complementary evidence of coverage."""@en ;
    dcat:keyword       "LexicalSimilarity"@en,
    "Lexical Overlap"@en,
    "Bench4KE"@en ;
    dqv:hasQualityMetric
        <https://w3id.org/bench4ke/metric/JaccardSimilarity>,
        <https://w3id.org/bench4ke/metric/BLEU>,
        <https://w3id.org/bench4ke/metric/ROUGELF1> ;
    dcterms:isPartOf   <https://w3id.org/bench4ke/task/CQGeneration> ;
    ftr:hasBenchmark   <https://w3id.org/bench4ke> ;
    ftr:supportedBy    <https://w3id.org/bench4ke> ;
    dpv:isApplicableFor <https://www.wikidata.org/wiki/Q184754> ;
    dcterms:creator    <https://orcid.org/0000-0002-0266-3452>,
                       <https://orcid.org/0009-0009-4332-1780> ;
    dcat:contactPoint  <https://orcid.org/0000-0002-0266-3452> ;
    dcterms:publisher  <https://ror.org/01111rn36>,
                       <https://ror.org/05w9g2j85>,
                       <https://stlab.istc.cnr.it/stlab/> ;
    dcterms:license    <http://creativecommons.org/licenses/by/4.0/> .

